{
    "compilerOptions": {
        "outDir": "./dist/",
        "moduleResolution": "node",
        "noImplicitAny": true,
        "allowSyntheticDefaultImports": true,
        "sourceMap": true,
        "module": "es6",
        "target": "es5",
        "allowJs": true,
        "jsx": "react",
        "jsxFactory": "PlainJSX.createElement",
        "jsxFragmentFactory": "PlainJSX.Fragment",
        "strict": true,
    },
    
    "include": [
        "src"
    ]
}